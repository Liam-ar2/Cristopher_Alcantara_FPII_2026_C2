        private void btnnueva_Click(object sender, EventArgs e)
        {
            txtdinero.Text = "";
            txtnumero.Text = "";
            txtprimera.Text = "--";
            txtsegunda.Text = "--";
            txttercera.Text = "--";
            txtresultado.Text = "Ingresa tus datos y presiona jugar";
